<?xml version="1.0" encoding="UTF-8"?>
<component name="SettingsScreen" extends="Group">
    <interface>
        <field id="authComplete" type="boolean" alwaysNotify="true" />
        <field id="itemSelected" type="assocarray" alwaysNotify="true" />
        <field id="navigateBack" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="SettingsScreen.brs" />

    <children>
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x1A1A2EFF"
        />
        <Group id="authGroup" translation="[0, 0]">
            <Rectangle
                id="authBox"
                translation="[560, 290]"
                width="800"
                height="500"
                color="0x232342FF"
            />
            <Label
                id="authTitle"
                translation="[960, 330]"
                horizAlign="center"
                text="Sign in to Plex"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
            />
            <Label
                id="authInstructions"
                translation="[960, 400]"
                horizAlign="center"
                text="Visit plex.tv/link and enter the code:"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
            />
            <Label
                id="pinCodeLabel"
                translation="[960, 480]"
                horizAlign="center"
                font="font:LargeBoldSystemFont"
                color="0xE5A00DFF"
            />
            <Label
                id="authStatus"
                translation="[960, 580]"
                horizAlign="center"
                font="font:SmallSystemFont"
                color="0xA0A0B0FF"
            />
            <Label
                id="serverStatus"
                translation="[960, 650]"
                horizAlign="center"
                font="font:SmallSystemFont"
                color="0xA0A0B0FF"
                visible="false"
            />
        </Group>
        <Group id="settingsGroup" translation="[0, 0]" visible="false">
            <Label
                id="settingsTitle"
                translation="[80, 40]"
                text="Settings"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
            />
            <LabelList
                id="settingsList"
                translation="[80, 120]"
                itemSize="[600, 60]"
                focusedColor="0xE5A00DFF"
                color="0xFFFFFFFF"
            />
        </Group>
        <LoadingSpinner
            id="loadingSpinner"
            translation="[960, 540]"
            visible="false"
        />
    </children>
</component>
