<component name="SearchScreen" extends="Group">
    <interface>
        <field id="itemSelected" type="assocarray" alwaysNotify="true" />
        <field id="navigateBack" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="pkg:/source/logger.brs" />
    <script type="text/brightscript" uri="SearchScreen.brs" />

    <children>
        <Rectangle id="background" width="1920" height="1080" color="0x000000FF" />

        <!-- Header: title + live query -->
        <Label id="titleLabel" translation="[80, 25]" text="Search"
            font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
        <Label id="queryLabel" translation="[260, 30]"
            font="font:MediumSystemFont" color="0xA0A0B0FF" width="1500" />

        <!-- Keyboard + action keys + separator + filter buttons (all in one row) -->
        <Group id="keyboardGroup" translation="[80, 80]" />

        <!-- Divider below keyboard row -->
        <Rectangle id="divider" translation="[80, 240]" width="1760" height="1" color="0xFFFFFF15" />

        <!-- Results grid (horizontal single-row, full width) -->
        <PosterGrid id="resultsGrid" translation="[80, 260]" gridWidth="1760" />

        <Group id="emptyState" translation="[960, 600]" visible="false">
            <Label id="emptyTitle" horizAlign="center" text="No results found"
                font="font:MediumBoldSystemFont" color="0x606070FF"
                width="600" translation="[-300, 0]" />
        </Group>

        <Group id="retryGroup" translation="[960, 600]" visible="false">
            <Label horizAlign="center" text="Something went wrong"
                font="font:LargeBoldSystemFont" color="0xFFFFFFFF"
                width="600" translation="[-300, 0]" />
            <Label horizAlign="center" text="Search failed"
                font="font:MediumSystemFont" color="0xA0A0B0FF"
                wrap="true" width="600" translation="[-300, 60]" />
            <ButtonGroup id="retryButton" translation="[-100, 130]"
                buttons='["Retry"]' />
        </Group>

        <LoadingSpinner id="loadingSpinner" />
    </children>
</component>
