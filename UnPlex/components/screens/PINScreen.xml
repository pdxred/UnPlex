<component name="PINScreen" extends="Group">
    <interface>
        <field id="state" type="string" value="idle" />
        <!-- "idle", "loading", "pinReady", "authenticated", "cancelled", "error" -->
        <field id="authToken" type="string" />
        <field id="servers" type="array" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="pkg:/source/logger.brs" />
    <script type="text/brightscript" uri="PINScreen.brs" />

    <children>
        <!-- Background -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000FF" />

        <!-- Main container centered -->
        <Group id="container" translation="[960, 340]">
            <!-- plex.tv/link URL -->
            <Label
                id="urlLabel"
                text="plex.tv/link"
                translation="[-200, 0]"
                width="400"
                height="60"
                horizAlign="center"
                vertAlign="center"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF" />

            <!-- PIN Code - large and centered -->
            <Label
                id="pinCodeLabel"
                text=""
                translation="[-300, 80]"
                width="600"
                height="150"
                horizAlign="center"
                vertAlign="center"
                font="font:LargeSystemFont"
                color="0xF3B125FF" />

            <!-- Loading indicator -->
            <Label
                id="loadingIndicator"
                text="..."
                translation="[-50, 240]"
                width="100"
                height="60"
                horizAlign="center"
                vertAlign="center"
                font="font:LargeBoldSystemFont"
                color="0xF3B125FF"
                visible="false" />

            <!-- Status text -->
            <Label
                id="statusLabel"
                text=""
                translation="[-300, 320]"
                width="600"
                height="40"
                horizAlign="center"
                vertAlign="center"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF" />

            <!-- Error label -->
            <Label
                id="errorLabel"
                text=""
                translation="[-300, 380]"
                width="600"
                height="60"
                horizAlign="center"
                vertAlign="center"
                font="font:MediumSystemFont"
                color="0xFF0000FF"
                visible="false" />
        </Group>

        <!-- Hint at bottom -->
        <Label
            id="hintLabel"
            text="Press Back to cancel"
            translation="[810, 1000]"
            width="300"
            height="40"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallSystemFont"
            color="0xA0A0B0FF" />
    </children>
</component>
