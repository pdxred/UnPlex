<?xml version="1.0" encoding="UTF-8"?>
<component name="EpisodeGrid" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChange" />
        <field id="itemSelected" type="integer" alwaysNotify="true" />
        <field id="itemFocused" type="integer" alwaysNotify="true" />
        <field id="escapeUp" type="boolean" alwaysNotify="true" value="false" />
        <field id="jumpToItem" type="integer" value="0" onChange="onJumpToItem" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/logger.brs" />
    <script type="text/brightscript" uri="EpisodeGrid.brs" />

    <children>
        <MarkupGrid
            id="grid"
            itemComponentName="EpisodeGridItem"
            numColumns="5"
            itemSize="[340, 240]"
            itemSpacing="[12, 16]"
            numRows="2"
            drawFocusFeedback="false"
        />
        <!-- Focus highlight: bright border around the focused item -->
        <!-- Use 4 thin rectangles to form a border (no fill overlay) -->
        <Rectangle id="focusBorderTop" color="0xF3B125FF" visible="false" />
        <Rectangle id="focusBorderBottom" color="0xF3B125FF" visible="false" />
        <Rectangle id="focusBorderLeft" color="0xF3B125FF" visible="false" />
        <Rectangle id="focusBorderRight" color="0xF3B125FF" visible="false" />
    </children>
</component>
