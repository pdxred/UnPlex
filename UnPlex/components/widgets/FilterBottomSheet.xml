<?xml version="1.0" encoding="UTF-8"?>
<component name="FilterBottomSheet" extends="Group">
    <interface>
        <field id="showSheet" type="boolean" onChange="onShowSheetChange" value="false" />
        <field id="sectionId" type="string" onChange="onSectionIdChange" />
        <field id="sectionType" type="string" value="1" />
        <field id="filterState" type="assocarray" alwaysNotify="true" />
        <field id="sheetDismissed" type="boolean" alwaysNotify="true" />
        <field id="genreDisplayNames" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="FilterBottomSheet.brs" />

    <children>
        <Group id="sheetGroup" translation="[340, 1080]" visible="false">
            <Rectangle
                id="sheetBg"
                width="1580"
                height="500"
                color="0x121314FF"
            />
            <Rectangle
                id="handleBar"
                translation="[740, 8]"
                width="100"
                height="4"
                color="0x505050FF"
            />

            <Group id="controlsGroup" translation="[40, 40]">
                <!-- Sort Column -->
                <Label
                    id="sortHeader"
                    text="Sort"
                    font="font:SmallBoldSystemFont"
                    color="0xF3B125FF"
                    translation="[0, 0]"
                />
                <RadioButtonList
                    id="sortList"
                    translation="[0, 35]"
                    itemSize="[350, 48]"
                    numRows="8"
                    drawFocusFeedback="true"
                    focusBitmapBlendColor="0xF3B125FF"
                />

                <!-- Unwatched Column -->
                <Label
                    id="unwatchedHeader"
                    text="Unwatched"
                    font="font:SmallBoldSystemFont"
                    color="0xF3B125FF"
                    translation="[400, 0]"
                />
                <LabelList
                    id="unwatchedList"
                    translation="[400, 35]"
                    itemSize="[350, 48]"
                    numRows="2"
                    drawFocusFeedback="true"
                    focusBitmapBlendColor="0xF3B125FF"
                />

                <!-- Genre Column -->
                <Label
                    id="genreHeader"
                    text="Genre"
                    font="font:SmallBoldSystemFont"
                    color="0xF3B125FF"
                    translation="[400, 140]"
                />
                <CheckList
                    id="genreList"
                    translation="[400, 175]"
                    itemSize="[350, 48]"
                    numRows="6"
                    drawFocusFeedback="true"
                    focusBitmapBlendColor="0xF3B125FF"
                />

                <!-- Year Column -->
                <Label
                    id="yearHeader"
                    text="Year"
                    font="font:SmallBoldSystemFont"
                    color="0xF3B125FF"
                    translation="[800, 0]"
                />
                <LabelList
                    id="yearList"
                    translation="[800, 35]"
                    itemSize="[350, 48]"
                    numRows="8"
                    drawFocusFeedback="true"
                    focusBitmapBlendColor="0xF3B125FF"
                />

                <!-- Clear All -->
                <ButtonGroup
                    id="clearAllButton"
                    translation="[1200, 0]"
                    buttons="[&quot;Clear All&quot;]"
                />
            </Group>

            <Animation id="slideUpAnim" duration="0.3" easeFunction="inOutCubic">
                <Vector2DFieldInterpolator
                    id="slideUpInterp"
                    key="[0.0, 1.0]"
                    keyValue="[[340, 1080], [340, 580]]"
                    fieldToInterp="sheetGroup.translation"
                />
            </Animation>
            <Animation id="slideDownAnim" duration="0.25" easeFunction="inOutCubic">
                <Vector2DFieldInterpolator
                    id="slideDownInterp"
                    key="[0.0, 1.0]"
                    keyValue="[[340, 580], [340, 1080]]"
                    fieldToInterp="sheetGroup.translation"
                />
            </Animation>
        </Group>
    </children>
</component>
