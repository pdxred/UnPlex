<?xml version="1.0" encoding="UTF-8"?>
<component name="PosterGridItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChange" />
    </interface>

    <script type="text/brightscript" uri="PosterGridItem.brs" />

    <children>
        <Poster
            id="poster"
            width="240"
            height="360"
        />
        <Label
            id="titleLabel"
            translation="[0, 365]"
            width="240"
            font="font:SmallestSystemFont"
            color="0xFFFFFFFF"
            horizAlign="center"
            maxLines="1"
        />
        <Rectangle
            id="progressTrack"
            translation="[0, 354]"
            width="240"
            height="6"
            color="0xFFFFFF33"
            visible="false"
        />
        <Rectangle
            id="progressFill"
            translation="[0, 354]"
            width="0"
            height="6"
            color="0xF3B125FF"
            visible="false"
        />
        <Rectangle
            id="unwatchedBadgeBg"
            translation="[200, 0]"
            width="40"
            height="32"
            color="0x00000088"
            visible="false"
        />
        <Label
            id="unwatchedCount"
            translation="[200, 4]"
            color="0xF3B125FF"
            visible="false"
            horizAlign="center"
            width="40"
        >
            <Font role="font" uri="pkg:/fonts/Inter-Bold.ttf" size="16" />
        </Label>
        <Rectangle
            id="watchedBadgeBg"
            translation="[200, 0]"
            width="40"
            height="32"
            color="0x00000088"
            visible="false"
        />
        <Label
            id="watchedBadge"
            translation="[200, 3]"
            text="&#x2714;"
            color="0xF3B125FF"
            visible="false"
            width="40"
            horizAlign="center"
        >
            <Font role="font" uri="pkg:/fonts/Inter-Bold.ttf" size="22" />
        </Label>
    </children>
</component>
