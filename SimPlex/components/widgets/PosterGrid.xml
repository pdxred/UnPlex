<?xml version="1.0" encoding="UTF-8"?>
<component name="PosterGrid" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChange" />
        <field id="itemSelected" type="integer" alwaysNotify="true" />
        <field id="loadMore" type="boolean" alwaysNotify="true" />
        <field id="gridWidth" type="integer" value="1620" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="PosterGrid.brs" />

    <children>
        <MarkupGrid
            id="grid"
            itemComponentName="PosterGridItem"
            numColumns="6"
            itemSize="[260, 410]"
            itemSpacing="[20, 40]"
            drawFocusFeedback="true"
            focusBitmapBlendColor="0xE5A00DFF"
            wrap="false"
        />
    </children>
</component>
