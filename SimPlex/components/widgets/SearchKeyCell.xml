<?xml version="1.0" encoding="UTF-8"?>
<component name="SearchKeyCell" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChange" />
        <field id="focusPercent" type="float" onChange="onFocusChange" />
    </interface>

    <script type="text/brightscript" uri="SearchKeyCell.brs" />

    <children>
        <Rectangle
            id="keyBg"
            width="64"
            height="52"
            color="0xFFFFFF10"
        />
        <Label
            id="keyLabel"
            width="64"
            height="52"
            horizAlign="center"
            vertAlign="center"
            font="font:MediumBoldSystemFont"
            color="0xCCCCCCFF"
        />
    </children>
</component>
