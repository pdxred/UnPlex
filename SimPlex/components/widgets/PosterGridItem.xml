            id="titleLabel"
            translation="[0, 365]"
            width="240"
            font="font:SmallestSystemFont"
            color="0xFFFFFFFF"
            horizAlign="center"
            maxLines="1"
        />
        <Rectangle
            id="progressTrack"
            translation="[0, 354]"
            width="240"
            height="6"
            color="0xFFFFFF33"
            visible="false"
        />
        <Rectangle
            id="progressFill"
            translation="[0, 354]"
            width="0"
            height="6"
            color="0xF3B125FF"
            visible="false"
        />
        <Poster
            id="unwatchedBadge"
            translation="[200, 0]"
            width="40"
            height="40"
            uri="pkg:/images/badge-unwatched.png"
            visible="false"
        />
        <Label
            id="unwatchedCount"
            translation="[218, 4]"
            font="font:SmallestSystemFont"
            color="0xFFFFFFFF"
            visible="false"
            horizAlign="right"
            width="18"
        />
        <Rectangle
            id="watchedBadgeBg"
            translation="[200, 0]"
            width="40"
            height="32"
            color="0x00000088"
            visible="false"
        />
        <Label
            id="watchedBadge"
            translation="[200, 2]"
            text="&#x2713;"
            font="font:SmallestSystemFont"
            color="0xF3B125FF"
            visible="false"
            width="40"
            horizAlign="center"
        />
