<?xml version="1.0" encoding="UTF-8"?>
<component name="VideoPlayer" extends="Group">
    <interface>
        <field id="ratingKey" type="string" />
        <field id="mediaKey" type="string" />
        <field id="startOffset" type="integer" value="0" />
        <field id="itemTitle" type="string" />
        <field id="control" type="string" onChange="onControlChange" />
        <field id="playbackComplete" type="boolean" alwaysNotify="true" />
        <field id="audioStreams" type="array" />
        <field id="subtitleStreams" type="array" />
        <field id="pgsRequested" type="assocarray" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="VideoPlayer.brs" />

    <children>
        <Video
            id="video"
            width="1920"
            height="1080"
            enableUI="true"
        />

        <TrackSelectionPanel
            id="trackPanel"
            visible="false"
        />

        <!-- Transcode pivot overlay - shown during PGS subtitle switch -->
        <Group id="transcodingOverlay" visible="false" translation="[0, 0]">
            <Rectangle
                width="1920"
                height="1080"
                color="0x00000088"
            />
            <Group translation="[860, 490]">
                <BusySpinner
                    id="transcodingSpinner"
                    translation="[60, 0]"
                    visible="true"
                />
                <Label
                    id="transcodingLabel"
                    translation="[0, 80]"
                    text="Switching subtitles..."
                    font="font:MediumSystemFont"
                    color="0xFFFFFFFF"
                    horizAlign="center"
                    width="200"
                />
            </Group>
        </Group>
    </children>
</component>
