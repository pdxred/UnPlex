<?xml version="1.0" encoding="UTF-8"?>
<component name="PlexAuthTask" extends="Task">
    <interface>
        <field id="action" type="string" />
        <!-- "requestPin", "checkPin", or "fetchResources" -->
        <field id="pinId" type="string" />
        <field id="pinCode" type="string" />
        <field id="expiresAt" type="string" />
        <!-- ISO 8601 timestamp of PIN expiration -->
        <field id="authToken" type="string" />
        <field id="servers" type="array" />
        <!-- Array of server objects after fetchResources -->
        <field id="error" type="string" />
        <field id="status" type="string" value="idle" />
        <!-- "idle", "loading", "pinReady", "authenticated", "waiting", "serversReady", "refreshing", "error" -->
    </interface>
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="pkg:/source/logger.brs" />
    <script type="text/brightscript" uri="PlexAuthTask.brs" />
</component>
