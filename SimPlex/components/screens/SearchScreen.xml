<?xml version="1.0" encoding="UTF-8"?>
<component name="SearchScreen" extends="Group">
    <interface>
        <field id="itemSelected" type="assocarray" alwaysNotify="true" />
        <field id="navigateBack" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="SearchScreen.brs" />

    <children>
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000FF"
        />
        <Label
            id="titleLabel"
            translation="[80, 40]"
            text="Search"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
        />
        <Keyboard
            id="keyboard"
            translation="[80, 120]"
        />
        <Label
            id="searchQueryLabel"
            translation="[700, 120]"
            font="font:MediumBoldSystemFont"
            color="0xFFFFFFFF"
            width="1140"
        />
        <PosterGrid
            id="resultsGrid"
            translation="[700, 200]"
            gridWidth="1140"
        />
        <Group id="emptyState" translation="[1270, 440]" visible="false">
            <Label
                id="emptyTitle"
                horizAlign="center"
                text="No results found"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="600"
                translation="[-300, 0]"
            />
        </Group>
        <Group id="retryGroup" translation="[1270, 440]" visible="false">
            <Label
                id="retryTitle"
                horizAlign="center"
                text="Something went wrong"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="600"
                translation="[-300, 0]"
            />
            <Label
                id="retryMessage"
                horizAlign="center"
                text="Search failed"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
                wrap="true"
                width="600"
                translation="[-300, 60]"
            />
            <ButtonGroup
                id="retryButton"
                translation="[-100, 130]"
                buttons="[&quot;Retry&quot;]"
            />
        </Group>
        <LoadingSpinner id="loadingSpinner" />
    </children>
</component>
