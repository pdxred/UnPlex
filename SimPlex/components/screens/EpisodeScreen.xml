<?xml version="1.0" encoding="UTF-8"?>
<component name="EpisodeScreen" extends="Group">
    <interface>
        <field id="ratingKey" type="string" onChange="onRatingKeyChange" />
        <field id="showTitle" type="string" />
        <field id="itemSelected" type="assocarray" alwaysNotify="true" />
        <field id="navigateBack" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="EpisodeScreen.brs" />

    <children>
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000FF"
        />
        <Label
            id="showTitleLabel"
            translation="[80, 40]"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
        />
        <LabelList
            id="seasonList"
            translation="[80, 120]"
            itemSize="[200, 50]"
            numRows="1"
            focusedColor="0xF3B125FF"
            color="0xFFFFFFFF"
        />
        <MarkupList
            id="episodeList"
            translation="[80, 200]"
            itemSize="[1760, 120]"
            itemSpacing="[0, 10]"
            drawFocusFeedback="true"
            focusBitmapBlendColor="0xF3B125FF"
            itemComponentName="EpisodeItem"
        />
        <Group id="emptyState" translation="[960, 440]" visible="false">
            <Label
                id="emptyTitle"
                horizAlign="center"
                text="No episodes found"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="600"
                translation="[-300, 0]"
            />
            <Label
                id="emptyMessage"
                horizAlign="center"
                text="This season doesn't have any episodes yet"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
                wrap="true"
                width="600"
                translation="[-300, 60]"
            />
        </Group>
        <Group id="retryGroup" translation="[960, 440]" visible="false">
            <Label
                id="retryTitle"
                horizAlign="center"
                text="Something went wrong"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="600"
                translation="[-300, 0]"
            />
            <Label
                id="retryMessage"
                horizAlign="center"
                text="Couldn't load episodes"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
                wrap="true"
                width="600"
                translation="[-300, 60]"
            />
            <ButtonGroup
                id="retryButton"
                translation="[-100, 130]"
                buttons="[&quot;Retry&quot;]"
            />
        </Group>
        <LoadingSpinner id="loadingSpinner" />
    </children>
</component>
