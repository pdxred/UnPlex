<?xml version="1.0" encoding="UTF-8"?>
<component name="DetailScreen" extends="Group">
    <interface>
        <field id="ratingKey" type="string" onChange="onRatingKeyChange" />
        <field id="itemType" type="string" />
        <field id="itemSelected" type="assocarray" alwaysNotify="true" />
        <field id="navigateBack" type="boolean" alwaysNotify="true" />
        <field id="watchStateChanged" type="assocarray" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/constants.brs" />
    <script type="text/brightscript" uri="DetailScreen.brs" />

    <children>
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x000000FF"
        />
        <Poster
            id="poster"
            translation="[80, 80]"
            width="640"
            height="360"
        />
        <Group id="metadataGroup" translation="[760, 80]">
            <Label
                id="titleLabel"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="1080"
            />
            <Label
                id="yearRuntimeLabel"
                translation="[0, 60]"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
            />
            <Label
                id="ratingLabel"
                translation="[0, 100]"
                font="font:MediumSystemFont"
                color="0xF3B125FF"
            />
            <Label
                id="genreLabel"
                translation="[0, 140]"
                font="font:SmallSystemFont"
                color="0xA0A0B0FF"
                width="1080"
            />
            <Label
                id="summaryLabel"
                translation="[0, 200]"
                font="font:SmallSystemFont"
                color="0xFFFFFFFF"
                width="1080"
                wrap="true"
                maxLines="5"
            />
        </Group>
        <Group id="progressGroup" translation="[80, 470]">
            <Rectangle
                id="detailProgressTrack"
                width="640"
                height="8"
                color="0xFFFFFF33"
                visible="false"
            />
            <Rectangle
                id="detailProgressFill"
                width="0"
                height="8"
                color="0xF3B125FF"
                visible="false"
            />
            <Label
                id="remainingLabel"
                translation="[0, 16]"
                font="font:SmallSystemFont"
                color="0xA0A0B0FF"
                visible="false"
                width="640"
            />
        </Group>
        <ButtonGroup
            id="buttonGroup"
            translation="[80, 530]"
            buttons="[]"
        />
        <Group id="retryGroup" translation="[960, 440]" visible="false">
            <Label
                id="retryTitle"
                horizAlign="center"
                text="Something went wrong"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFFF"
                width="600"
                translation="[-300, 0]"
            />
            <Label
                id="retryMessage"
                horizAlign="center"
                text="Couldn't load details"
                font="font:MediumSystemFont"
                color="0xA0A0B0FF"
                wrap="true"
                width="600"
                translation="[-300, 60]"
            />
            <ButtonGroup
                id="retryButton"
                translation="[-100, 130]"
                buttons="[&quot;Retry&quot;]"
            />
        </Group>
        <LoadingSpinner id="loadingSpinner" />
    </children>
</component>
